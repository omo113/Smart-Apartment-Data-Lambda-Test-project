{
  "GoogleGeocoding": {
    "BaseUrl": "https://geocode.googleapis.com",
    "GeocodePath": "/v4/geocode/address",
    "TimeoutSeconds": 10,
    "ApiKeyEnvironmentVariableName": "GOOGLE_GEOCODING_API_KEY",
    "ApiKeySecretJsonKey": "apiKey"
  },
  "GeocodeCache": {
    "TableName": "smart-apartment-geocode-cache",
    "CacheDurationDays": 30
  }
}
