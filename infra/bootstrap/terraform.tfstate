            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"TerraformStateBucketList\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:ListBucket\",\n        \"s3:GetBucketLocation\"\n      ],\n      \"Resource\": \"arn:aws:s3:::smart-apartment-tfstate-590183851689-eu-north-1\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"s3:prefix\": \"demo/*\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"TerraformStateObjectAccess\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:PutObject\",\n        \"s3:GetObject\",\n        \"s3:DeleteObject\"\n      ],\n      \"Resource\": \"arn:aws:s3:::smart-apartment-tfstate-590183851689-eu-north-1/demo/*\"\n    },\n    {\n      \"Sid\": \"TerraformStateLockAccess\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"dynamodb:PutItem\",\n        \"dynamodb:GetItem\",\n        \"dynamodb:DescribeTable\",\n        \"dynamodb:DeleteItem\"\n      ],\n      \"Resource\": \"arn:aws:dynamodb:eu-north-1:590183851689:table/smart-apartment-tf-locks-demo\"\n    },\n    {\n      \"Sid\": \"ManageDemoInfrastructure\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"secretsmanager:*\",\n        \"logs:*\",\n        \"lambda:*\",\n        \"iam:UpdateAssumeRolePolicy\",\n        \"iam:UntagRole\",\n        \"iam:TagRole\",\n        \"iam:PutRolePolicy\",\n        \"iam:PutRolePermissionsBoundary\",\n        \"iam:PassRole\",\n        \"iam:ListRoleTags\",\n        \"iam:ListRolePolicies\",\n        \"iam:ListAttachedRolePolicies\",\n        \"iam:GetRolePolicy\",\n        \"iam:GetRole\",\n        \"iam:DeleteRolePolicy\",\n        \"iam:DeleteRolePermissionsBoundary\",\n        \"iam:DeleteRole\",\n        \"iam:CreateRole\",\n        \"dynamodb:*\",\n        \"apigateway:*\"\n      ],\n      \"Resource\": \"*\"\n    }\n  ]\n}",
